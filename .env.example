# Copie para .env.local e preencha com os valores do seu projeto Supabase.
# (Settings > API no painel do Supabase)
#
# A ANON_KEY aceita tanto a legacy "anon public" (eyJ...) quanto a nova
# "publishable key" (sb_publishable_...). As duas funcionam no dashboard.
# NUNCA use a secret key (sb_secret_...) aqui — ela ignora RLS e e privada.

NEXT_PUBLIC_SUPABASE_URL=https://xxxxxxxxxxxx.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=sb_publishable_xxx   # ou a legacy eyJhbGciOiJ...
